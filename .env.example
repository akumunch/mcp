# ── Atlassian / Jira (via Rovo MCP) ─────────────────────────────────────────
JIRA_EMAIL=your-email@example.com
ATLASSIAN_MCP_TOKEN=your-atlassian-api-token-here
JIRA_BASE_URL=https://yoursite.atlassian.net
ROVO_CLOUD_ID=
ROVO_MCP_URL=https://mcp.atlassian.com/v1/mcp

# ── Google Calendar (via @cocal/google-calendar-mcp) ────────────────────────
GOOGLE_CALENDAR_MCP_COMMAND=npx
GOOGLE_CALENDAR_MCP_ARGS=-y @cocal/google-calendar-mcp
# Absolute path to the OAuth client credentials JSON downloaded from
# Google Cloud Console (Desktop app type — see README for setup steps)
GOOGLE_OAUTH_CREDENTIALS=C:\Users\YOUR_USERNAME\path\to\gcp-oauth.keys.json

# ── Slack (official Slack MCP server) ───────────────────────────────────────
SLACK_USER_TOKEN=xoxp-your-slack-user-token-here

# ── Gemini Planner ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
